---
import H1 from "../components/h1.astro";
import Navigation from "../components/navigation";
import RootLayout from "../layouts/RootLayout.astro";
import WarpBackground from "../components/warp-background";
import HeroButtons from "../components/HeroButtons";
import AvailableForWork from "../components/AvailableForWork";
---

<RootLayout>
  <main>
    <div class="group relative w-full min-h-dvh flex items-center justify-center">
      <div class="absolute w-full h-dvh -z-10">
        <WarpBackground
          color1="#09090b"
          color2="#27272a"
          color3="#52525b"
          speed={0.6}
          swirl={0.5}
          swirlIterations={10}
          shapeScale={0.3}
          client:load
        />
      </div>

      <div class="p-4 sm:p-8 absolute w-full h-dvh flex flex-col justify-between z-10">
        <div>
          <H1 size="large">
            Luiza <br /> LeBlanc
          </H1>
        </div>

        <div>
          <AvailableForWork className="py-4" client:load />

          <div class="mb-2 sm:mb-4 flex items-center justify-between flex-wrap gap-4">
            <HeroButtons client:load />
            <Navigation client:load />
          </div>
        </div>
      </div>
    </div>
  </main>
</RootLayout>
