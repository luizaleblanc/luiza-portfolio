---
import MobileHero from "../components/HeroParts/MobileHero.astro";
import OtherHero from "../components/HeroParts/OtherHero.astro";
---

<section>
  <div class="sm:hidden">
    <MobileHero />
  </div>
  <div class="hidden sm:inline">
    <OtherHero />
  </div>
</section>

<script>
  const letters = "ABCDEFGHIJKLMNOPQRSTUVWXYZ";

  let interval: number;

  document.getElementById("myName")!.onmouseover = (event: any) =>
    hackedTextEffect(event);

  function hackedTextEffect(event: any = null) {
    let iteration = 0;

    clearInterval(interval);

    interval = setInterval(() => {
      let target: HTMLElement;

      if (event === null) {
        target = document.getElementById("myName")!;
      } else {
        target = event.target as HTMLElement;
      }

      target.innerText = target.innerText
        .split("")
        .map((_: string, index: number) => {
          if (index < iteration) {
            return target.dataset.value![index];
          }

          return letters[Math.floor(Math.random() * 26)];
        })
        .join("");

      if (iteration >= target.dataset.value!.length) {
        clearInterval(interval);
      }

      iteration += 1 / 3;
    }, 42);
  }

  console.log("loaded");
  hackedTextEffect();
</script>
